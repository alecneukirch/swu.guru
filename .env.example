# .env.example — Copy to .env and fill in real values
# NEVER commit .env to source control

# -----------------------------------------------------------------------
# Domain & TLS
# -----------------------------------------------------------------------
DOMAIN=yourdomain.com
ACME_EMAIL=your@email.com

# Cloudflare API token for DNS-01 Let's Encrypt challenge
# Requires Zone:DNS:Edit permission on your zone
CF_DNS_API_TOKEN=your_cloudflare_token_here

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_UID=1000
APP_GID=1000

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
POSTGRES_DB=swuguru
POSTGRES_USER=swuguru
POSTGRES_PASSWORD=changeme_strong_password

# -----------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------
REDIS_PASSWORD=changeme_strong_password

# -----------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_strong_password
